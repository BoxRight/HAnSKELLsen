    "principal_contract": {
      "normative_clauses": [
        {
          "id": "clause_pago_renta",
          "source_clause": "Primera",
          "text": "El arrendatario pagará al arrendador la renta mensual pactada, íntegra e indivisible.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "oblig", "act": "pago_renta" }
        },
        {
          "id": "clause_mes_forzoso",
          "source_clause": "Segunda",
          "text": "Todo mes de arrendamiento le es forzoso y lo pagará íntegro aun cuando únicamente ocupe la localidad un solo día.",
          "form": "constraint",
          "constraint": "renta_mensual.periodicidad == 'mensual'"
        },
        {
          "id": "clause_plazo",
          "source_clause": "Tercera",
          "text": "El término del arrendamiento será de ___.",
          "form": "definition",
          "defines": "plazo_arrendamiento"
        },
        {
          "id": "clause_prohibicion_subarrendamiento",
          "source_clause": "Cuarta",
          "text": "Queda expresamente prohibido traspasar o subarrendar todo o parte del inmueble arrendado.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "forbid", "fact_predicate": "subarriende" }
        },
        {
          "id": "clause_recepcion_inmueble",
          "source_clause": "Quinta",
          "text": "El arrendatario declara haber recibido el inmueble en perfecto estado.",
          "form": "declaration",
          "generates_fact": "recepcion_inmueble"
        },
        {
          "id": "clause_mejoras",
          "source_clause": "Sexta",
          "text": "Cualquier mejora que hiciere el arrendatario queda a beneficio de la finca y requiere permiso escrito del arrendador.",
          "form": "implies",
          "antecedent": { "act": "haga_mejoras" },
          "consequent": { "effect": "beneficio_finca" },
          "constraint": "requires_written_permission"
        },
        {
          "id": "clause_uso_habitacional",
          "source_clause": "Séptima",
          "text": "El arrendatario hará uso del inmueble únicamente para habitación.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "forbid", "fact_predicate": "use_para_otro_fin" },
          "rescission_trigger": true
        },
        {
          "id": "clause_prohibicion_retencion",
          "source_clause": "Octava",
          "text": "El inquilino no podrá retener ni descontar de la renta cantidad alguna.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "forbid", "fact_predicate": "retenga_renta" }
        },
        {
          "id": "clause_prohibicion_sustancias",
          "source_clause": "Novena",
          "text": "No podrá tener substancias corrosivas, materias inflamables o peligrosas.",
          "form": "standalone_forbid",
          "consequent": { "deontic": "forbid", "fact_predicate": "almacene_sustancias_peligrosas" }
        },
        {
          "id": "clause_conservacion",
          "source_clause": "Décima",
          "text": "El arrendatario recibe el inmueble con todo el servicio sanitario en perfecto estado y se compromete a conservarlo.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "oblig", "act": "conserve_inmueble" }
        },
        {
          "id": "clause_deposito_garantia",
          "source_clause": "Décima primera",
          "text": "Para garantizar el cumplimiento de este contrato entregará el inquilino la cantidad de $___ la cual se devolverá cuando desocupe.",
          "form": "implies",
          "antecedent": { "fact": "contrato_vigente" },
          "consequent": { "deontic": "oblig", "act": "entrega_deposito" },
          "conditional_return": {
            "condition": "desocupe_sin_deudas",
            "act": "devolucion_deposito"
          }
        },
        {
          "id": "clause_fiador",
          "source_clause": "Décima segunda",
          "text": "Firma este contrato ___ como fiador solidario del inquilino.",
          "form": "implies",
          "antecedent": { "fact": "es_fiador_solidario" },
          "consequent": { "deontic": "oblig", "act": "garantice_pago" }
        },
        {
          "id": "clause_terminacion",
          "source_clause": "Decimotercera",
          "text": "Cuando el contrato se haya celebrado por tiempo determinado, concluye el día prefijado sin necesidad de desahucio.",
          "form": "implies",
          "antecedent": { "fact": "vencido_plazo" },
          "consequent": { "effect": "terminacion_contrato" }
        }
      ],

